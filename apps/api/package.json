{
  "name": "@sgc/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "start": "node dist/main.js",
    "worker": "node dist/worker.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run src",
    "test:e2e": "vitest run test/e2e --no-file-parallelism",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@sgc/auth": "workspace:*",
    "@sgc/config": "workspace:*",
    "@sgc/db": "workspace:*",
    "@sgc/documents": "workspace:*",
    "@sgc/types": "workspace:*",
    "argon2": "^0.44.0",
    "bwip-js": "^4.11.2",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.1",
    "exceljs": "^4.4.0",
    "express": "5.1.0",
    "fast-xml-parser": "5.7.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "redis": "5.8.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/bwip-js": "^3.2.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.5",
    "@types/express-serve-static-core": "^5.1.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.6",
    "@types/qrcode": "^1.5.6",
    "@types/serve-static": "^2.2.0",
    "pg-protocol": "^1.15.0",
    "pg-types": "^4.1.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "undici-types": "^8.7.0",
    "vitest": "^4.0.15"
  }
}
