NODE_ENV=production
APP_ENV=production
APP_VERSION=1.0.0

API_HOST_PORT=3334
WEB_HOST_PORT=3100
MARKETING_HOST_PORT=3101
HOST_BIND_ADDRESS=127.0.0.1
NEXT_PUBLIC_API_URL=https://api.useorien.com.br/api/v1
MARKETING_APP_URL=https://useorien.com.br
NEXT_PUBLIC_APP_NAME=Orien
WEB_APP_URL=https://app.useorien.com.br
NEXT_PUBLIC_MARKETING_URL=https://useorien.com.br
NEXT_PUBLIC_BRAND_DOMAIN=https://useorien.com.br

POSTGRES_OWNER_PASSWORD=replace-with-a-long-random-secret
SGC_APP_PASSWORD=replace-with-a-different-long-random-secret
DATABASE_URL=postgresql://sgc_app:unused@postgres:5432/sgc
DATABASE_MIGRATION_URL=postgresql://sgc_owner:unused@postgres:5432/sgc
REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes
JWT_REFRESH_SECRET=replace-with-at-least-32-random-bytes
COOKIE_SECRET=replace-with-at-least-32-random-bytes
COOKIE_SECURE=true
PASSWORD_PEPPER=replace-with-a-long-random-pepper

PLATFORM_OWNER_EMAIL=admin@useorien.com.br
PLATFORM_OWNER_PASSWORD=replace-with-a-strong-initial-password

ASAAS_ENV=sandbox
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
WHATSAPP_PLATFORM_MODE=disabled
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# E-mail transacional da plataforma (Resend)
RESEND_API_KEY=
ALERT_FROM_EMAIL=alertas@useorien.com.br
SMTP_PROVIDER=resend
SMTP_FROM="Orien <no-reply@useorien.com.br>"
HEALTHCHECK_WEBHOOK_URL=
