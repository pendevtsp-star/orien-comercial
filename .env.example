NODE_ENV=development
APP_ENV=local
APP_VERSION=1.18.0

WEB_PORT=3000
MARKETING_PORT=3001
API_PORT=3334
NEXT_PUBLIC_API_URL=http://localhost:3334/api/v1
NEXT_PUBLIC_MARKETING_URL=http://localhost:3001
MARKETING_APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Orien
WEB_APP_URL=http://localhost:3000
ADMIN_APP_URL=http://localhost:3002
ADMIN_HOST_PORT=3102
NEXT_PUBLIC_BRAND_DOMAIN=https://useorien.com.br

DATABASE_URL=postgres://sgc_app:sgc_app_password@localhost:5432/sgc
DATABASE_MIGRATION_URL=postgres://sgc_owner:sgc_owner_password@localhost:5432/sgc
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes
JWT_REFRESH_SECRET=replace-with-at-least-32-random-bytes
COOKIE_SECRET=replace-with-at-least-32-random-bytes
PASSWORD_PEPPER=replace-with-random-server-side-pepper

PLATFORM_OWNER_EMAIL=admin@example.com
PLATFORM_OWNER_PASSWORD=ChangeMe123!DoNotUseInProduction
UPLOAD_DIR=/app/uploads
INTEGRATIONS_ENCRYPTION_KEY=replace-with-a-strong-32-plus-character-server-key
SEED_DEMO_USERS=false
DEMO_USER_PASSWORD=

ASAAS_ENV=sandbox
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=

WHATSAPP_PLATFORM_MODE=disabled
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

SMTP_PROVIDER=disabled
SMTP_FROM="Orien <no-reply@useorien.com.br>"
RESEND_API_KEY=
ALERT_FROM_EMAIL=alertas@useorien.com.br

SENTRY_DSN=
SENTRY_ENVIRONMENT=local
NEXT_PUBLIC_SENTRY_DSN=

